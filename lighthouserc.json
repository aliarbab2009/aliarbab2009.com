{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/projects",
        "http://localhost:3000/projects/stocksaathi",
        "http://localhost:3000/projects/bolhisaab",
        "http://localhost:3000/projects/maglock",
        "http://localhost:3000/about",
        "http://localhost:3000/resume",
        "http://localhost:3000/contact"
      ],
      "numberOfRuns": 3,
      "startServerCommand": "pnpm start",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 30000,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --disable-dev-shm-usage --headless=new",
        "throttlingMethod": "simulate",
        "throttling": {
          "rttMs": 40,
          "throughputKbps": 10240,
          "cpuSlowdownMultiplier": 1
        },
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:pwa": "off",

        "first-contentful-paint": ["error", { "maxNumericValue": 1500 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 1500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.05 }],
        "total-blocking-time": ["error", { "maxNumericValue": 100 }],
        "interactive": ["error", { "maxNumericValue": 2000 }],
        "speed-index": ["error", { "maxNumericValue": 1500 }],

        "resource-summary:script:size": ["error", { "maxNumericValue": 220000 }],
        "resource-summary:stylesheet:size": ["error", { "maxNumericValue": 25000 }],
        "resource-summary:font:size": ["error", { "maxNumericValue": 200000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 800000 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 1500000 }],

        "uses-text-compression": "error",
        "color-contrast": "error",
        "viewport": "error",
        "document-title": "error",
        "html-has-lang": "error",
        "meta-description": "error",
        "robots-txt": "error",
        "canonical": "error",
        "is-on-https": "off",
        "redirects-http": "off",
        "uses-http2": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "server": {
      "port": 9001
    }
  }
}
