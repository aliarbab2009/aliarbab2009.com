# pnpm/npm configuration — aliarbab2009.com
# Safety knobs only; nothing project-specific that would belong in package.json.

# When adding a dep with `pnpm add`, save it as an exact version (no ^ or ~).
# Matches the runtime-dep pinning policy from P4.18.
save-prefix=

# Always prefer https registry traffic; reject self-signed certs.
strict-ssl=true

# Run `pnpm audit` automatically on install. Advisory locally; CI is the
# enforcing gate.
audit-level=moderate

# Hide the npm "fund" nag during install.
fund=false

# pnpm 9+: fail an install if any sub-tree integrity check fails.
# Re-hashes every package against the lockfile sha512 on install.
verify-store-integrity=true

# Match pnpm's default explicitly so a future major-version flip doesn't
# silently change behavior.
strict-peer-dependencies=false
