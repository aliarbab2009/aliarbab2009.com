# ============================================================
# aliarbab2009.com environment variables
# Copy to .env.local and fill in. NEVER commit the filled-in .env*
# ============================================================

# Public site URL (used for canonical URLs, OG images, sitemaps)
NEXT_PUBLIC_SITE_URL="https://aliarbab2009.com"

# Contact form — Resend transactional email
# Get a key at https://resend.com — free tier: 100 emails/day, 3000/mo
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@aliarbab2009.com"
CONTACT_TO_EMAIL="ali@aliarbab2009.com"

# GitHub stats — a personal access token with public_repo scope
# Lifts API rate limit from 60/h (anonymous) to 5000/h
# Create at https://github.com/settings/tokens (Classic) or Fine-grained
GITHUB_TOKEN=""

# Analytics (optional — Plausible instead of GA4 for privacy)
PLAUSIBLE_DOMAIN=""

# StockSaathi live-stats proxy (server-only; not shipped to client)
# Optional: only needed if /api/stocksaathi-stats route is deployed
STOCKSAATHI_STATS_URL=""
